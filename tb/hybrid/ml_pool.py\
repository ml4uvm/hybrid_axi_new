import csv


class MLTestPool:
    """
    Handles ML-prioritized / clustered AXI testcases.
    """

    def __init__(self, file_path):
        self.testcases = self._load_testcases(file_path)

        if not self.testcases:
            raise ValueError("ML pool is empty!")

    def _load_testcases(self, file_path):
        testcases = []

        with open(file_path, "r") as f:
            reader = csv.DictReader(f)

            for row in reader:
                testcase = {
                    "txn_type": int(row["txn_type"]),
                    "addr_category": int(row["addr_category"]),
                    "data_type": int(row["data_type"]),
                    "predicted_gain": float(row["predicted_gain"]),
                    "cluster": int(row["cluster"]),
                }

                testcases.append(testcase)

        return testcases

    def get_all(self):
        return list(self.testcases)

    def __len__(self):
        return len(self.testcases)

